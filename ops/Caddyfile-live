zdvartcc.org {
	handle /vatis.json {
		reverse_proxy https://raw.githubusercontent.com {
			header_up Host {upstream_hostport}
			header_down Content-Type "application/octet-stream"
		}
		rewrite * /vZDV-ARTCC/vzdv/refs/heads/master/static/vatis.json
	}

	handle_path /assets/* {
		root * /home/zdv/vzdv/assets
		file_server
	}

	@robots {
		method GET
		path_regexp ^/robots\.txt$
	}

	handle {
		reverse_proxy :3000
	}
}

training.zdvartcc.org {
	handle {
		reverse_proxy :3001
	}
}
